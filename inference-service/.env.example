# --- HTTP API ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Auth ---
# If set, all /v1/* endpoints require "Authorization: Bearer <key>".
# Leave empty for unauthenticated dev mode.
API_KEY=

# --- Backend selection ---
#
# ПРАВИЛО ТАЙПИТ (#5 SKILL.md): для прод-данных — ТОЛЬКО локальный backend.
# Корпоративные документы не уходят в публичные облака LLM.
#
# Допустимые значения:
#   stub          — deterministic, no ML; для CI и smoke-тестов
#   openai_compat — РЕКОМЕНДУЕМО для прода: локальный inference-сервер
#                   через OpenAI-compatible API (Ollama / vLLM / llama.cpp
#                   / LM Studio / SGLang / TGI). Требует OPENAI_BASE_URL +
#                   OPENAI_MODEL. См. docker-compose.local-models.yml +
#                   MODELS.md для подбора модели.
#   qwen          — Qwen2.5-VL прямо через transformers (требует GPU + [qwen]).
#                   Используется только когда openai_compat недоступен.
#   claude        — РЕЗЕРВ: Anthropic Claude. ТОЛЬКО для синтетических
#                   документов / отладки промптов / dev. Запрещён для
#                   реальных корп.данных.
#   openai        — РЕЗЕРВ: OpenAI Cloud. То же ограничение что и claude.
BACKEND=stub

# --- Anthropic / Claude backend (used when BACKEND=claude) ---
# РЕЗЕРВ — только для синтетики и dev. Не использовать для прод-данных.
# Configured-ness (key present?) is reported via /v1/providers/status
# regardless of whether `claude` is the active backend — this lets the
# operator UI show "configured but inactive" status.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-opus-4-7-20260301
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_TIMEOUT_SECONDS=120

# --- OpenAI backend (placeholder; not implemented yet) ---
OPENAI_API_KEY=

# --- Qwen-VL backend (only used when BACKEND=qwen) ---
QWEN_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
QWEN_DEVICE=auto
QWEN_DTYPE=auto
QWEN_MAX_NEW_TOKENS=2048
# Where transformers caches downloaded weights inside the container.
HF_HOME=/app/.hf-cache
