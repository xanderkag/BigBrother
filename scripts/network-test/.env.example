# --- Куда стучимся ---
PARSDOCS_API_URL=http://10.10.13.10:8085/api/v1

# Bearer-токен. Получить: админ-UI → My API tokens → Create.
# Не коммитить заполненный .env! .env закрыт корневым .gitignore репо.
PARSDOCS_TOKEN=

# --- Корпус ---
# Каталог с реальными документами на хосте прогона (вне репо).
# Допустимые расширения: pdf, jpg, jpeg, png, bmp, tif, tiff, webp.
CORPUS_DIR=/opt/parsdocs-corpus

# Опционально — путь до подвыборки (txt со списком относительных путей).
# Если пусто, скрипт берёт всё из CORPUS_DIR (find).
CORPUS_LIST=

# --- Polling ---
POLL_INTERVAL_S=2
JOB_TIMEOUT_S=300

# --- Load (run-load.sh) ---
CONCURRENCY=4

# --- Soak (run-soak.sh) ---
SOAK_DURATION_S=7200   # 2 часа
SOAK_RPM=30            # подача 30 док/мин

# --- Stress (run-stress.sh) ---
STRESS_DURATION_S=900  # 15 минут
STRESS_RPM=90          # 150% от номинала (подгоните под baseline)
