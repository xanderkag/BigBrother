# --- HTTP API ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
MAX_UPLOAD_MB=50

# --- Worker ---
# Parallel jobs per worker process. Tesseract is single-threaded CPU-bound,
# so > 1 yields no speed-up on a one-core machine and may degrade throughput.
# Bump only if your workload is mostly LLM/network bound, or you're on a
# multi-core box dedicated to OCR.
WORKER_CONCURRENCY=1

# Hard cap on the multipart `metadata` field, in bytes. Above this the
# upload is rejected with 400; protects the JSONB column from blob abuse.
MAX_METADATA_BYTES=65536

# --- Background sweepers (run inside the worker process) ---
# Pending-job sweeper: re-enqueues rows stuck in 'pending' (e.g. Redis was
# down at the moment of enqueue). Grace gives the normal path time to land.
PENDING_SWEEPER_INTERVAL_MS=60000
PENDING_SWEEPER_GRACE_SECONDS=60

# File cleanup: deletes uploaded blobs after the job reaches a terminal
# state and the retention window elapses. The DB row stays for audit; only
# `file_path` is NULLed and the file removed from STORAGE_DIR.
FILE_CLEANUP_INTERVAL_MS=3600000
FILE_RETENTION_DAYS=30

# --- Auth ---
# Single Bearer token guarding /api/v1/* routes. Empty value disables auth
# (dev mode). /health and /ready are always public for orchestrator probes.
# Generate a strong value, e.g.: openssl rand -hex 32
API_KEY=

# --- Secrets-at-rest ---
# Master-ключ для envelope-шифрования секретов, хранящихся в БД
# (api-ключи провайдеров в provider_settings). AES-256-GCM, 64-hex-символьная
# строка = 32 байта.
#
# Сгенерировать: openssl rand -hex 32
#
# В production это поле ОБЯЗАТЕЛЬНО. Если пусто и NODE_ENV=production —
# сервис не стартует.
# В dev пусто = deterministic dev-default (см. src/storage/secrets.ts).
#
# ВНИМАНИЕ: смена ключа делает уже зашифрованные секреты нечитаемыми.
# Для ротации:
#   1. Расшифровать всё под старым ключом, сохранить во временную колонку.
#   2. Сменить SECRETS_ENCRYPTION_KEY.
#   3. Запустить `npm run migrate:secrets -- --apply`.
# Полноценный rotate-скрипт — TODO (TECH_DEBT).
SECRETS_ENCRYPTION_KEY=

# --- PostgreSQL ---
DATABASE_URL=postgres://docservice:docservice@postgres:5432/docservice

# --- Redis (BullMQ) ---
REDIS_URL=redis://redis:6379

# --- Local file storage ---
# Mounted as Docker volume; absolute path inside the container.
STORAGE_DIR=/app/data

# --- OCR pipeline thresholds ---
# Confidence at which an engine's output is accepted without falling through to the next engine.
PDF_TEXT_ACCEPT_THRESHOLD=0.90
TESSERACT_ACCEPT_THRESHOLD=0.75
VISION_LLM_ACCEPT_THRESHOLD=0.75
NEEDS_REVIEW_THRESHOLD=0.60

# Phase 1 regex parsers (invoice, UPD) call LLM /extract when their own confidence
# is below this. Set to 0 to disable LLM-fallback (pure regex behaviour).
LLM_FALLBACK_THRESHOLD=0.70

# Tesseract languages (comma-separated 3-letter codes installed in the image).
TESSERACT_LANGS=rus+eng

# --- LLM inference service (Qwen-VL or other) ---
# Leave empty to disable; pipeline falls back to the next engine.
# When wired to ../inference-service via the shared `ai-platform` Docker network:
#   LLM_INFERENCE_URL=http://inference:8000
LLM_INFERENCE_URL=
LLM_API_KEY=
LLM_TIMEOUT_MS=60000

# --- Yandex Cloud Vision ---
# WARNING (152-ФЗ): при активном движке изображение документа уходит в
# Yandex Cloud. Для документов с персональными данными (ТТН с паспортом
# водителя, CMR с контактами отправителя) это регуляторный риск. Per-job
# opt-out пока не реализован — см. TECH_DEBT.md пункт I8. До тех пор в
# проде, обрабатывающем такие документы, держите ключ пустым — engine
# автоматически выпадет из OCR-цепочки.
YANDEX_VISION_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_TIMEOUT_MS=30000

# --- Webhook delivery ---
# HMAC secret signs the body; consumer verifies with header "X-DocService-Signature: sha256=<hex>".
WEBHOOK_HMAC_SECRET=change-me
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=5
