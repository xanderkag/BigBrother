# --- HTTP API ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
MAX_UPLOAD_MB=50

# --- Worker ---
# Parallel jobs per worker process. Tesseract is single-threaded CPU-bound,
# so > 1 yields no speed-up on a one-core machine and may degrade throughput.
# Bump only if your workload is mostly LLM/network bound, or you're on a
# multi-core box dedicated to OCR. Prod (10.10.13.10) runs 2 — OCR path is
# largely vision-LLM (network-bound), so slots overlap on I/O, not CPU.
WORKER_CONCURRENCY=2

# Hard deadline for a queued job (seconds). If a job has been waiting longer
# than this it is dropped without retrying (UnrecoverableError). Protects
# against a pile-up of stale retries after a prolonged LLM/OCR outage.
# Default: 4 hours (14400). Set higher only for very slow OCR pipelines.
JOB_MAX_AGE_SECONDS=14400

# Rate-limiting: max requests per minute per API-key (or IP if no key).
# /health and /ready are always exempt. Set to 0 to disable entirely.
RATE_LIMIT_PER_MINUTE=200

# A3: Named client keys (JSON map). Each key grants same access as API_KEY
# but tags logs/audit with the caller name. Rotate keys per client without
# changing the root API_KEY. Example (no spaces inside single-quoted string):
# API_KEYS_JSON='{"abc123def456":"erp-system","xyz789":"mobile-app"}'
API_KEYS_JSON=

# Hard cap on the multipart `metadata` field, in bytes. Above this the
# upload is rejected with 400; protects the JSONB column from blob abuse.
MAX_METADATA_BYTES=65536

# --- Background sweepers (run inside the worker process) ---
# Pending-job sweeper: re-enqueues rows stuck in 'pending' (e.g. Redis was
# down at the moment of enqueue). Grace gives the normal path time to land.
PENDING_SWEEPER_INTERVAL_MS=60000
PENDING_SWEEPER_GRACE_SECONDS=60

# File cleanup: deletes uploaded blobs after the job reaches a terminal
# state and the retention window elapses. The DB row stays for audit; only
# `file_path` is NULLed and the file removed from STORAGE_DIR.
FILE_CLEANUP_INTERVAL_MS=3600000
FILE_RETENTION_DAYS=30

# Slow-job warning — если общее время обработки job'а превышает этот
# порог, в лог пишется `slow job` с bottleneck-шагом (ocr/classify/
# extract/validate). Алертить по level=warn + msg='slow job'.
SLOW_JOB_THRESHOLD_MS=60000

# Audit-log retention: фоновая чистка таблицы audit_log (изменения
# document_types / provider_settings через UI). Без этой чистки таблица
# растёт линейно от частоты админских правок: при 1000 правок/день —
# ~5-20 GB за 3-5 лет (before/after JSONB по 5-20 KB на строку).
# Дефолт 365 дней — типичный IT-change-audit. Под регуляторные
# финансовые требования (5-7 лет) поднимайте до 1825-2555.
AUDIT_LOG_SWEEP_INTERVAL_MS=86400000
AUDIT_LOG_RETENTION_DAYS=365

# --- Auth ---
# Single Bearer token guarding /api/v1/* routes. /health and /ready are always
# public for orchestrator probes. Generate a strong value: openssl rand -hex 32
#
# REQUIRED unless ALLOW_NO_AUTH=true. If BOTH API_KEY and API_KEYS_JSON are
# empty AND ALLOW_NO_AUTH is unset, the service REFUSES TO START (fail-closed),
# so prod can never silently run with auth disabled.
API_KEY=

# P0 security opt-out — DEV ONLY. Set to `true` to run with auth fully
# disabled (every request becomes system super_admin). Required to boot when
# no API_KEY / API_KEYS_JSON is configured. Default unset = secure (boot fails
# closed). NEVER set this in production.
ALLOW_NO_AUTH=

# --- Secrets-at-rest ---
# Master-ключ для envelope-шифрования секретов, хранящихся в БД
# (api-ключи провайдеров в provider_settings). AES-256-GCM, 64-hex-символьная
# строка = 32 байта.
#
# Сгенерировать: openssl rand -hex 32
#
# В production это поле ОБЯЗАТЕЛЬНО. Если пусто и NODE_ENV=production —
# сервис не стартует.
# В dev пусто = deterministic dev-default (см. src/storage/secrets.ts).
#
# ВНИМАНИЕ: смена ключа делает уже зашифрованные секреты нечитаемыми.
# Для ротации:
#   1. Расшифровать всё под старым ключом, сохранить во временную колонку.
#   2. Сменить SECRETS_ENCRYPTION_KEY.
#   3. Запустить `npm run migrate:secrets -- --apply`.
# Полноценный rotate-скрипт — TODO (TECH_DEBT).
SECRETS_ENCRYPTION_KEY=

# --- PostgreSQL ---
DATABASE_URL=postgres://docservice:docservice@postgres:5432/docservice

# --- Redis (BullMQ) ---
REDIS_URL=redis://redis:6379

# --- File storage ---
# Mounted as Docker volume; absolute path inside the container.
# Для STORAGE_BACKEND=s3 этот же путь используется как write-through локальный
# кэш (чтобы post-upload pipeline не делал GetObject для свежесохранённого файла).
STORAGE_DIR=/app/data

# A2: backend для file storage.
#   local — пишем только в STORAGE_DIR (default).
#   s3    — пишем в S3/MinIO + локальный кэш в STORAGE_DIR. Horizontal scale
#           становится возможен (worker в другом pod'е тянет недостающее
#           через S3 на лету). Чтобы стало полным shared-nothing, OCR-движки
#           должны уметь не зависеть от локального диска — это deferred (см.
#           TECH_DEBT A2 archive entry).
# При выборе `s3` обязательны S3_BUCKET, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY;
# без них сервис откажется стартовать.
STORAGE_BACKEND=local

# S3 / MinIO settings. Используются только при STORAGE_BACKEND=s3.
S3_BUCKET=
# Для MinIO: http://minio:9000 (внутри docker-сети). Для AWS — оставить пустым,
# SDK сам выберет endpoint по region.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# MinIO требует path-style (bucket в URL). AWS S3 принимает оба.
# Безопасный default — true (работает везде).
S3_FORCE_PATH_STYLE=true

# --- OCR pipeline thresholds ---
# Confidence at which an engine's output is accepted without falling through to the next engine.
PDF_TEXT_ACCEPT_THRESHOLD=0.90
TESSERACT_ACCEPT_THRESHOLD=0.75
VISION_LLM_ACCEPT_THRESHOLD=0.75
NEEDS_REVIEW_THRESHOLD=0.60

# Phase 1 regex parsers (invoice, UPD) call LLM /extract when their own confidence
# is below this. Set to 0 to disable LLM-fallback (pure regex behaviour).
LLM_FALLBACK_THRESHOLD=0.70

# Если OCR-текст длиннее этого порога И parser_kind=llm_extract — orchestrator
# автоматически переключается на двухпроходный MultiPassLlmParser (header + items
# батчами). Решает проблему «потери середины» на длинных таблицах и снижает
# токены на каждый /v1/extract. Установить 0 чтобы выключить авто-режим
# (multipass всё равно сработает явно через parser_kind=llm_extract_multipass).
MULTIPASS_AUTO_BYTES=30000

# MultiPassLlmParser tuning (применяется когда multipass активен). Дефолты —
# текущие захардкоженные значения; меняйте под контекст-окно модели и нагрузку
# на inference-service.
#   *_HEAD/TAIL_BYTES  — сколько байт начала/конца текста идёт в Pass 1 (шапка).
#   CHUNK_SIZE_BYTES   — размер куска items[] для Pass 2.
#   MAX_PASSES         — потолок числа кусков (защита от timeout-цепочки).
#   MAX_ITEMS_TOTAL    — потолок финального items[].
#   ITEMS_PARALLELISM  — макс одновременных extract-вызовов к inference (429-риск).
MULTIPASS_HEADER_HEAD_BYTES=4000
MULTIPASS_HEADER_TAIL_BYTES=2000
MULTIPASS_CHUNK_SIZE_BYTES=12000
# 24 (было 10): куски мельче (TARGET_ROWS), прежний потолок молча резал
# товарный хвост больших .xls. При parallelism 6 это 4 волны.
MULTIPASS_MAX_PASSES=24
MULTIPASS_MAX_ITEMS_TOTAL=1000
# На vLLM (continuous batching) безопасно 6; admission-гейт inference = 16.
MULTIPASS_ITEMS_PARALLELISM=6
# SPEED-1: закрывать кусок по N табличным строкам (держит ВЫХОД вызова в
# безопасных ~2-4К токенов — по ExtractBench провал растёт с объёмом вывода,
# не входа). 0 = выключить (резать только по CHUNK_SIZE_BYTES).
MULTIPASS_TARGET_ROWS=30
# SPEED-5: входить в multipass ТАКЖЕ если табличных строк больше N (прокси
# объёма вывода) — даже когда вход мал по байтам. Ловит мульти-док сегменты
# (инвойс с сотней позиций), которые иначе single-shot → обрыв на 8192 токенах.
# 0 = выключить строковый триггер (только по AUTO_BYTES).
MULTIPASS_AUTO_ROWS=40
# COMPLEX-DEFER: док с числом табличных строк выше порога — «сложный»: полный
# extract занял бы слот воркера на 10-15+ мин (мульти-док мега-книга) и тормозил
# бы очередь. Такой док классифицируем, extract ОТКЛАДЫВАЕМ (needs_review +
# маркер _complex_deferred), копим для батч-разбора. 0 = выключить. Норм. инвойс
# <50 строк — порог высокий, ловит только выбросы.
COMPLEX_DOC_ROW_THRESHOLD=400
# Stall-guard: «точный подвисон» — джоба, зависшая в processing (updated_at
# заморожен = нет прогресса). После скольких безуспешных reclaim'ов метим её
# failed + маркер _stall_deferred (для батч-перепроверки), а не ретраим вечно.
# 0 = выключить (старое поведение — всегда re-enqueue). 2 = консервативно
# (легит-медленный multipass успевает финализироваться между reclaim'ами).
STALL_MAX_RECLAIMS=2

# Tesseract languages (comma-separated 3-letter codes installed in the image).
TESSERACT_LANGS=rus+eng

# Устойчивость tesseract к тяжёлым/патологическим растровым сканам.
# Бинарь зовётся напрямую с timeout+SIGKILL: зависшая страница убивается и
# каскад переключается на vision-llm/yandex, а не держит слот воркера.
TESSERACT_TIMEOUT_MS=90000
# Потолок страниц на документ (0 = без лимита) — тяжёлый многостраничный скан
# не молотится бесконечно.
TESSERACT_MAX_PAGES=0
# OMP_THREAD_LIMIT для tesseract — не переподписывать CPU при concurrency>1.
TESSERACT_OMP_THREADS=2
# Фото/PNG: если tesseract отдал меньше этого числа символов — не акцептуем
# его результат и пробуем vision-llm (обрывки с фото проходят по confidence,
# но извлекать из них нечего). Только image/*, PDF не трогает.
TESSERACT_IMAGE_MIN_TEXT_ACCEPT=800

# Vision-OCR: сколько страниц скана распознавать параллельно. 1 = как было
# (по одной). На vLLM (параллельный KV-cache) поднять до 3-4 → многостраничные
# сканы в разы быстрее; на Ollama (serial) оставить 1.
VISION_PAGE_PARALLELISM=1

# --- DEEP-PASS: глубокий разбор нераспознанного остатка ---
# (docs/DEEP-PASS-SPEC.md) Не опознан / OCR-refusal → широкая категория +
# резюме + возврат в конвейер, если тип оказался рабочим. Отдельная честная
# категория «не документ» для скриншотов/мусора. Всё на локальных моделях.
DEEP_PASS_ENABLED=false
# Сколько первых символов OCR-текста уходит в text-путь (classify видит 2500).
DEEP_PASS_TEXT_CHARS=8000
# Меньше этого текста — идём в vision по картинке первой страницы.
DEEP_PASS_MIN_TEXT=300
# NB: для картинок/сканов vision-проверка присвоенного типа выполняется ВСЕГДА
# (кроме hint/vlm) — уверенное согласие keyword+LLM на OCR-тексте надписей с
# коробки ложно (фото → cert_of_origin с conf=1.0). Порог не настраивается.

# --- Office vision-fallback (P1-B) ---
# Картиночный docx (скан вставлен в Word): текста мало → гоним картинки в vision.
OFFICE_IMAGE_FALLBACK_ENABLED=true
# Ниже стольких символов текста docx считаем «почти пустым» и пробуем vision.
OFFICE_MIN_TEXT_CHARS=200
# Картинки мельче этого (KB) — логотипы/печати, в vision не идут.
OFFICE_IMAGE_MIN_KB=50
# Потолок числа картинок на документ, уходящих в vision (latency/GPU-guard).
OFFICE_IMAGE_MAX_COUNT=8
# «Скан-размер» картинки (KB): полная страница, не логотип.
OFFICE_IMAGE_LARGE_KB=200
# Есть скан-картинка И текста меньше этого → картинко-доминированный docx → vision.
OFFICE_IMAGE_DOC_MAX_CHARS=2500

# --- LLM inference service ---
#
# ПРАВИЛО ТАЙПИТ (#5 в SKILL.md): для документов с реальными корп.данными
# здесь должен быть указан ТОЛЬКО локальный inference-service (наш контейнер
# `inference` в общей docker-сети `ai-platform`), а внутри него BACKEND=
# openai_compat (Ollama / vLLM / llama.cpp / LM Studio). Cloud LLM (Claude,
# OpenAI) для прод-данных не используется — это резервный режим для синтетики,
# отладки промптов и dev. Контроль режима — на стороне inference-service,
# см. его .env.example.
#
# Leave empty to disable; pipeline falls back to the next engine.
# When wired to ../inference-service via the shared `ai-platform` Docker network:
#   LLM_INFERENCE_URL=http://inference:8000
LLM_INFERENCE_URL=
LLM_API_KEY=
LLM_TIMEOUT_MS=60000

# Vision-OCR провайдер для сканов (VisionLlmEngine). Указывает id строки
# provider_settings, которую doc-service берёт для распознавания растровых
# сканов через vision-модель (напр. qwen3-vl:32b). Отделён от extraction-
# провайдера намеренно: OCR-движку нужна vision-capable модель, а не
# default text-провайдер извлечения. Пусто → берётся первая активная
# строка с vision=true (findActiveVision). См. OCR-VISION-DECOUPLE в TECH_DEBT.
OCR_VISION_PROVIDER_ID=

# --- LLM gateway (local): doc-service как OpenAI-совместимый LLM-шлюз ---
#
# Когда включено, doc-service публикует top-level OpenAI-совместимые роуты
# /v1/chat/completions и /v1/models для внешних клиентов (клиент №1 — SLAI
# AI-чат). Это аутентифицированный (Bearer named-key из API_KEYS_JSON)
# passthrough ПРЯМО на локальный GPU Ollama (OpenAI-compat) с серверной
# подменой model по карте алиасов. Облачные бэкенды НЕ используются (правило
# ТАЙПИТ #5: corp-данные только on-prem). См.
# docs/EXT_LLM_GATEWAY_LOCAL_IMPL_TZ_2026-06-08.md.
#
# Фича-флаг: false → роуты /v1/* не регистрируются (fail-closed).
LLM_GATEWAY_ENABLED=false
# Endpoint GPU Ollama (OpenAI-compat), ВКЛЮЧАЯ /v1. ВАЖНО: это НЕ
# LLM_INFERENCE_URL (тот указывает на inference-service с кастомными
# /v1/classify, /v1/extract). Шлюз идёт прямо в Ollama, минуя inference.
# Пусто → fallback на LLM_INFERENCE_URL.
LLM_GATEWAY_BASE_URL=http://10.10.33.10:11434/v1
# Алиас по умолчанию, когда клиент не указал model или указал неизвестный.
LLM_GATEWAY_DEFAULT_ALIAS=parsdocs-chat
# Карта alias→backend (JSON). Публикуем клиенту алиасы (стабильны), backend
# двигаем без правок у клиента. Значение — либо строка (backend-tag на дефолтном
# LLM_GATEWAY_BASE_URL), либо объект {"model","upstream"} — свой upstream у алиаса
# (per-alias upstream). Пример: ассистент SLAI в vLLM 8100/tool-calling, а vision
# остаётся в Ollama 11434:
#   {"parsdocs-chat":"qwen3-vl:32b",
#    "parsdocs-assistant":{"model":"qwen36-vllm","upstream":"http://10.10.33.10:8100/v1"}}
LLM_GATEWAY_MODELS_JSON={"parsdocs-chat":"mistral-small3.1"}
# Таймаут одного chat-вызова к Ollama (мс). Локальные модели могут думать долго.
LLM_GATEWAY_TIMEOUT_MS=120000

# --- Yandex Cloud Vision OCR ---
# WARNING (152-ФЗ): при активном движке изображение документа уходит в
# Yandex Cloud. Для документов с персональными данными (ТТН с паспортом
# водителя, CMR с контактами отправителя) есть PII-гард (I8): per-job
# metadata._disable_external_ocr=true и глобальный YANDEX_DISABLE_FOR_PII
# ниже. Движок ВЫКЛЮЧЕН пока key+folder пустые (isAvailable()=false) —
# оставьте их пустыми чтобы поведение цепочки не менялось. Runbook
# включения: docs/YANDEX_OCR_SETUP.md.
YANDEX_VISION_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_TIMEOUT_MS=30000
# Модель OCR для recognizeText: page (default), table, page-column-sort, handwritten
YANDEX_OCR_MODEL=page
# Per-type табличная модель: для типов из YANDEX_TABLE_MODEL_TYPES вместо
# YANDEX_OCR_MODEL применяется YANDEX_TABLE_MODEL (по умолчанию table).
# CSV slug'ов (case-insensitive). Пусто = везде YANDEX_OCR_MODEL.
# Пример: сканы счёт-фактур / УПД распознаются точнее табличной моделью.
YANDEX_TABLE_MODEL=table
YANDEX_TABLE_MODEL_TYPES=
# Per-job override модели — metadata._yandex_ocr_model (побеждает всё выше).
# Когда true и Yandex настроен — он становится ПЕРВЫМ scan-движком (перед
# tesseract / vision-llm) для растровых входов. Нативный текст (pdf-text/
# xlsx/docx) всё равно впереди. PII-гард сохраняется. Default false —
# Yandex остаётся last-resort fallback'ом, порядок цепочки не меняется.
YANDEX_PREFER_FOR_SCANS=false

# --- DaData party-by-INN enrichment (enrich-стадия) ---
# Российский сервис suggestions.dadata.ru. После extract пайплайн ищет ИНН
# контрагентов и подтягивает официальную карточку ЕГРЮЛ (название, адрес,
# руководитель, статус) в extracted._enrichment.
#
# 152-ФЗ: шлём ТОЛЬКО ИНН юрлиц — это публичные данные ЕГРЮЛ, не ПДн. Никаких
# изображений / содержимого документа наружу не уходит.
#
# Пусто = enrich-стадия недоступна (DadataClient.isAvailable()=false), даже
# если потребитель включил enrich_enabled в своём профиле. Стадия additive и
# fail-soft — никогда не роняет job.
DADATA_API_KEY=
DADATA_TIMEOUT_MS=10000
# TTL in-memory кэша по ИНН (мс). Default 24h — данные ЕГРЮЛ меняются редко.
DADATA_CACHE_TTL_MS=86400000

# --- Webhook delivery (parsdocs → SLAI) ---
# HMAC secret signs the body; consumer verifies with header "X-DocService-Signature: sha256=<hex>".
WEBHOOK_HMAC_SECRET=change-me
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=5

# --- Inbound category-sync (SLAI → parsdocs) ---
# Verifies HMAC on incoming SLAI→parsdocs nomenclature sync (X-SLAI-Signature).
# Читается в config.ts; без него inbound category-sync молча работает с undefined-секретом.
SLAI_TO_PARSDOCS_HMAC_SECRET=change-me

# Webhook sweeper — фоновый процесс, который добивает неудачные доставки.
# Накапливает webhook_attempts через несколько прогонов: 5 → 10 → 15. После
# WEBHOOK_SWEEPER_HARD_LIMIT попыток job выпадает из sweeper'а и только
# ручной POST /jobs/:id/redeliver-webhook сможет его перезапустить.
WEBHOOK_SWEEPER_INTERVAL_MS=900000        # 15 минут между прогонами
WEBHOOK_SWEEPER_GRACE_MINUTES=60          # сколько ждать после первой неудачи
WEBHOOK_SWEEPER_HARD_LIMIT=15             # лимит attempts на job (3 волны × 5 ретраев)

# --- PII / 152-ФЗ контроль ---
# Per-job opt-out из Yandex Vision для документов с персональными данными.
# Если в metadata передан _disable_external_ocr=true, router пропускает Yandex
# для этого job'а. Установить YANDEX_DISABLE_FOR_PII=true чтобы выключить
# Yandex для всех job'ов где классификатор детектит PII-документ (TTN, CMR
# с водительскими данными). См. I8 в TECH_DEBT.
YANDEX_DISABLE_FOR_PII=false

# --- Preprocess pipeline (новые форматы, обработка до основного OCR) ---
#
# EXIF stripping: снимать ли GPS / автора / серийник камеры с фото перед
# сохранением оригинала. По 152-ФЗ это персональные данные. Снимается через
# ImageMagick mogrify -strip. По дефолту включено. Выключить только если
# EXIF важен для forensics / авторства (но тогда нужна compensating control).
STRIP_EXIF_ON_UPLOAD=true

# Максимальный объём распакованного содержимого ZIP/RAR/7Z архивов.
# Защита от bomb-архивов (1 МБ → 100 ГБ при распаковке). Превышение →
# error_code=BOMB_ARCHIVE, job → failed.
MAX_UNPACKED_BYTES=500000000

# Включить sidecar-контейнер unoserver для конвертации DOCX/XLSX → PDF.
# Без него parsedocs отклоняет DOCX/XLSX с 415 + сообщением «сохраните как
# PDF из Word/Excel». unoserver требует +600 МБ к docker (LibreOffice
# headless), поэтому опционально. См. docs/FILE_TYPES_SPEC.md.
ENABLE_DOCX_SIDECAR=false
UNOSERVER_URL=http://unoserver:2003

# --- Auto-dedup по hash содержимого файла ---
# Если включено: при создании job сервис считает sha256 содержимого и
# проверяет нет ли уже job с тем же hash в этой организации за последние
# AUTO_DEDUP_WINDOW_HOURS часов. Если есть — возвращает существующий job_id
# вместо создания дубля. Защищает от «бухгалтер случайно прислал тот же
# счёт повторно». См. docs/FILE_INTAKE_OVERVIEW.md.
AUTO_DEDUP_BY_HASH=false
AUTO_DEDUP_WINDOW_HOURS=24

# BILL-1: курс USD→RUB для сведения расхода валютных провайдеров (Anthropic/
# OpenAI) в единый ₽-итог — решение владельца 2026-07-23. Курс ФИКСИРУЕТСЯ в
# снимке задачи: смена значения не меняет уже посчитанные задачи.
# 0 = не задан → валютный расход помечается estimate (НЕ считается нулём).
COST_FX_USD_RUB=0
