{
  "name": "doc-service",
  "version": "0.1.0",
  "description": "Universal document processing service: OCR + structured extraction for transport and accounting documents",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "migrate": "tsx src/scripts/migrate.ts up",
    "migrate:down": "tsx src/scripts/migrate.ts down",
    "migrate:create": "tsx src/scripts/migrate.ts create",
    "migrate:secrets": "tsx src/scripts/migrate-secrets.ts",
    "rotate:secrets": "tsx src/scripts/rotate-secrets.ts",
    "smoke": "tsx src/scripts/smoke.ts",
    "eval": "tsx src/scripts/eval/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:css": "tailwindcss -c web/tailwind.config.cjs -i web/input.css -o web/vendor/tailwind.css --minify",
    "build:css:watch": "tailwindcss -c web/tailwind.config.cjs -i web/input.css -o web/vendor/tailwind.css --watch"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.4",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "file-type": "^19.6.0",
    "ioredis": "^5.4.1",
    "mammoth": "^1.12.0",
    "mime-types": "^2.1.35",
    "node-pg-migrate": "^7.9.1",
    "node-tesseract-ocr": "^2.2.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "undici": "^7.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "pdfkit": "^0.18.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
